# ==========================================
# VidyaMitra Frontend Environment Variables
# ==========================================
# Copy this file to .env and fill in your actual values

# API Configuration
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# ==================== Supabase ====================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-supabase-public-key

# ==================== Application Settings ====================
VITE_APP_TITLE=VidyaMitra - Career Intelligence
VITE_APP_VERSION=1.0.0

# ==================== Feature Flags ====================
VITE_ENABLE_MOCK_INTERVIEW=true
VITE_ENABLE_AI_FEEDBACK=true
VITE_ENABLE_VIDEO_RESOURCES=true
VITE_ENABLE_PROGRESS_TRACKING=true

# ==================== Analytics (Optional) ====================
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_MIXPANEL_TOKEN=your-mixpanel-token

# ==================== Debug ====================
VITE_DEBUG=false
